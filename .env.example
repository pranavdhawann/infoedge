# Required
GROQ_API_KEY=

# Optional — Contact form (EmailJS frontend + Resend backend)
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
RESEND_API_KEY=
CONTACT_EMAIL=

# Optional — Multi-source news aggregation (falls back to Yahoo Finance if not set)
NEWSAPI_KEY=
FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=
CURRENTS_API_KEY=

# Optional — Supabase persistent cache (falls back to in-memory cache if not set)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# App settings
FLASK_ENV=production
PORT=8080
LOG_LEVEL=INFO
